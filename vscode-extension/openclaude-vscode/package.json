{
  "name": "open-matrix-vscode",
  "displayName": "OPEN MATRIX",
  "description": "Acompanhante prático do VS Code para o OPEN MATRIX com inicialização inteligente e painel de controle integrado.",
  "version": "0.2.0",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:openmatrix.start",
    "onCommand:openmatrix.startInWorkspaceRoot",
    "onCommand:openmatrix.openDocs",
    "onCommand:openmatrix.openSetupDocs",
    "onCommand:openmatrix.openWorkspaceProfile",
    "onCommand:openmatrix.openControlCenter",
    "onCommand:openmatrix.newChat",
    "onCommand:openmatrix.openChat",
    "onCommand:openmatrix.resumeSession",
    "onCommand:openmatrix.abortChat",
    "onView:openmatrix.controlCenter",
    "onView:openmatrix.chat"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "src/chat/**",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "openmatrix.start",
        "title": "OPEN MATRIX: Iniciar no Terminal",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.startInWorkspaceRoot",
        "title": "OPEN MATRIX: Iniciar na Raiz do Espaço de Trabalho",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.openDocs",
        "title": "OPEN MATRIX: Abrir Repositório",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.openSetupDocs",
        "title": "OPEN MATRIX: Abrir Guia de Configuração",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.openWorkspaceProfile",
        "title": "OPEN MATRIX: Abrir Perfil do Espaço de Trabalho",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.openControlCenter",
        "title": "OPEN MATRIX: Abrir Centro de Controle",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.newChat",
        "title": "OPEN MATRIX: Nova Conversa",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.openChat",
        "title": "OPEN MATRIX: Abrir Painel de Conversa",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.resumeSession",
        "title": "OPEN MATRIX: Retomar Sessão",
        "category": "OPEN MATRIX"
      },
      {
        "command": "openmatrix.abortChat",
        "title": "OPEN MATRIX: Abortar Geração",
        "category": "OPEN MATRIX"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openmatrix",
          "title": "OPEN MATRIX",
          "icon": "media/openmatrix.svg"
        }
      ]
    },
    "views": {
      "openmatrix": [
        {
          "id": "openmatrix.chat",
          "name": "Conversa",
          "type": "webview"
        },
        {
          "id": "openmatrix.controlCenter",
          "name": "Centro de Controle",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "openmatrix.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "OPEN MATRIX",
      "properties": {
        "openmatrix.launchCommand": {
          "type": "string",
          "default": "open-matrix",
          "description": "Comando executado no terminal integrado ao iniciar o OPEN MATRIX."
        },
        "openmatrix.terminalName": {
          "type": "string",
          "default": "OPEN MATRIX",
          "description": "Nome da aba do terminal integrado para sessões do OPEN MATRIX."
        },
        "openmatrix.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Opcionalmente define CLAUDE_CODE_USE_OPENAI=1 nos terminais do OPEN MATRIX iniciados."
        },
        "openmatrix.permissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": ["default", "acceptEdits", "bypassPermissions", "plan"],
          "enumDescriptions": [
            "Solicitar permissão para cada uso de ferramenta (requer aprovação manual)",
            "Aprovar automaticamente edições de arquivos, solicitar para outras operações (recomendado)",
            "Aprovar automaticamente todas as operações sem solicitar",
            "Modo somente leitura — nenhuma modificação de arquivo é permitida"
          ],
          "description": "Modo de permissão para sessões de conversa. Controla quais operações de ferramentas são auto-aprovadas."
        }
      }
    },
    "themes": [
      {
        "label": "OPEN MATRIX Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/OPEN-MATRIX-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "bun test src",
    "lint": "node scripts/lint.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "openmatrix",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gitlawb/openclaude"
  },
  "license": "MIT"
}
